{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "exclude": ["types"],
    "entry": [
        "source/packages/**/*.entry-point.ts!",
        "source/**/*.test.ts!",
        "integration-tests/**/*.ts!",
        "dependency-cruiser.config.js",
        "mocha.config.base.cjs",
        "mocha.config.unit-tests.cjs",
        "mocha.config.integration-tests.cjs",
        "packtory.config.js"
    ],
    "project": ["source/**/*.ts!", "integration-tests/**/*.ts!", "*.js", "*.cjs", "!integration-tests/fixtures/**/*"],
    "ignoreDependencies": ["c8", "eslint", "foo", "prettier"],
    "ignoreBinaries": []
}
