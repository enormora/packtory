{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": [
        "benchmarks/**/*.ts",
        "source/packages/**/*.entry-point.ts!",
        "source/**/*.test.ts",
        "source/**/*.property.ts",
        "source/**/*.type-test.ts",
        "source/test-libraries/github-release-gate-test-support.ts!",
        "source/build-support/mutation-timeout/check-mutation-timeouts.entry-point.ts!",
        "source/build-support/mutation-timeout/check-mutation-timeouts.ts!",
        "integration-tests/**/*.ts",
        "dependency-cruiser.config.js",
        "mocha.config.property-tests.json",
        "mocha.config.unit-tests.json",
        "mocha.config.integration-tests.json",
        "packtory.config.js",
        "tstyche.json"
    ],
    "project": [
        "benchmarks/**/*.ts",
        "source/**/*.ts!",
        "integration-tests/**/*.ts",
        "*.js",
        "!integration-tests/fixtures/**/*",
        "!source/**/*.test.ts!",
        "!source/**/*test-support.ts!",
        "!source/test-libraries/**/*.ts!"
    ],
    "tags": ["-@internal"],
    "ignoreDependencies": ["@ls-lint/ls-lint", "c8", "foo", "jscpd"],
    "ignoreBinaries": []
}
