{
    "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/api/schema/stryker-schema.json",
    "testRunner": "mocha",
    "coverageAnalysis": "perTest",
    "tempDirName": "target/.stryker-tmp",
    "allowConsoleColors": false,
    "concurrency": 2,
    "testFiles": ["source/**/*.test.ts"],
    "mochaOptions": {
        "no-package": true,
        "no-opts": true,
        "no-config": true,
        "ui": "tdd",
        "extension": ["ts"]
    },
    "testRunnerNodeArgs": ["--experimental-strip-types", "--enable-source-maps"],
    "mutate": [
        "source/**/*.ts",
        "!source/**/*.test.ts",
        "!source/**/*.property.ts",
        "!source/test-libraries/**/*.ts",
        "!source/packages/**/*.entry-point.ts"
    ],
    "ignorePatterns": ["node_modules", "target", ".git", "integration-tests"],
    "disableTypeChecks": true,
    "thresholds": {
        "high": 100,
        "low": 100,
        "break": 88.08
    },
    "reporters": ["clear-text", "html", "json"],
    "clearTextReporter": {
        "reportMutants": true,
        "reportScoreTable": false,
        "reportTests": false,
        "logTests": false,
        "skipFull": true
    },
    "htmlReporter": {
        "fileName": "target/stryker/index.html"
    },
    "jsonReporter": {
        "fileName": "target/stryker/mutation-report.json"
    }
}
